# ============================================================
#  PlanMyShaadi — Frontend Environment Variables
#  Copy this to .env and fill your values
# ============================================================

# Backend API base URL
VITE_API_URL=http://localhost:8000/api/v1

# App name
VITE_APP_NAME=PlanMyShaadi

# Razorpay public key (safe to expose on frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx